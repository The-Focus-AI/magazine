---
import { getCollection, getEntry } from 'astro:content';
import CoverEmblem from '../../components/CoverEmblem.astro';
// Note: intentionally NOT importing magazine.css — paged.js needs clean
// flowable content with no absolute positioning, sticky nav, or @media
// screen breakpoints competing with the @page rules below.

export async function getStaticPaths() {
  const issues = (await getCollection('issues')).filter((i) => !i.data.draft);
  return issues.map((issue) => ({
    params: { slug: issue.slug },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const { Content: CoverContent } = await issue.render();

const allSections = await getCollection('sections');
const sections = allSections
  .filter((s) => s.data.issue === issue.slug)
  .sort((a, b) => a.data.section_number - b.data.section_number);

const rendered = await Promise.all(sections.map((s) => s.render()));

const verticalLabel: Record<string, string> = {
  state: 'State',
  surface: 'Surface',
  runtime: 'Runtime',
  harness: 'Harness',
  local: 'Local',
  wire: 'Wire',
};

const publishedString = issue.data.published
  .toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  .toUpperCase();

const issueNumPadded = String(issue.data.issue_number).padStart(2, '0');
const vertical = issue.data.vertical;
const verticalUp = verticalLabel[vertical].toUpperCase();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{verticalUp} № {issueNumPadded} · {issue.data.issue_title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..900,0..100;1,9..144,300..900,0..100&family=Newsreader:ital,opsz,wght@0,6..72,300..800;1,6..72,300..800&family=IBM+Plex+Mono:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Paged.js: config BEFORE polyfill loads, then manual trigger.
         Using is:inline on all three so Astro doesn't module-ify them,
         otherwise they load async and PagedConfig isn't set in time. -->
    <script is:inline>
      window.PagedConfig = { auto: false };
    </script>
    <script is:inline src="https://unpkg.com/pagedjs@0.4.3/dist/paged.polyfill.js"></script>
    <script is:inline>
      function waitForImages() {
        const imgs = Array.from(document.images);
        return Promise.all(
          imgs.map((img) =>
            img.complete
              ? Promise.resolve()
              : new Promise((res) => {
                  img.addEventListener('load', res);
                  img.addEventListener('error', res);
                })
          )
        );
      }
      window.addEventListener('DOMContentLoaded', () => {
        Promise.all([document.fonts.ready, waitForImages()]).then(() => {
          if (window.PagedPolyfill && typeof window.PagedPolyfill.preview === 'function') {
            window.PagedPolyfill.preview();
          }
        });
      });
    </script>
  </head>
  <body data-mag={vertical} class="print-body">
    <div class="mag-root">

      <!-- ═════ Cover page ═════ -->
      <section class="print-cover">
        <header class="print-cover-top">
          <div class="print-cover-publisher">
            TheFocus.AI Press<br/>
            Cornwall, Connecticut
          </div>
          <div class="print-cover-number">
            Issue No. {issueNumPadded}<br/>
            {publishedString}
          </div>
        </header>

        <h1 class="print-cover-masthead">
          {verticalLabel[vertical]}<span class="period">.</span>
        </h1>

        <div class="print-cover-emblem">
          <CoverEmblem vertical={vertical} />
        </div>

        <div class="print-cover-lines">
          <p class="print-cover-kicker">The Feature</p>
          <h2 class="print-cover-subtitle">{issue.data.issue_title}</h2>
          <p class="print-cover-dek">{issue.data.subtitle}</p>
          <p class="print-cover-tagline">&ldquo;{issue.data.tagline}&rdquo;</p>
        </div>

        <footer class="print-cover-footer">
          <span>{verticalUp}—{issueNumPadded}</span>
          <span>TheFocus.AI Magazines</span>
        </footer>
      </section>

      <!-- ═════ Contents page ═════ -->
      {sections.length > 0 && (
        <section class="print-toc">
          <div class="print-toc-label">Contents · {publishedString}</div>
          <h2>In this issue.</h2>
          <ol class="print-toc-list">
            {sections.map((section) => {
              const marker = section.data.section_marker ?? `§ ${section.data.section_number}`;
              return (
                <li>
                  <span class="num">{marker}</span>
                  <span class="title">
                    {section.data.title}
                    {section.data.summary && <em>{section.data.summary.slice(0, 72)}{section.data.summary.length > 72 ? '…' : ''}</em>}
                  </span>
                  <span class="page" data-href={`#s-${section.data.section_number}`}>
                    <a href={`#s-${section.data.section_number}`}>·</a>
                  </span>
                </li>
              );
            })}
          </ol>

          {issue.data.summary && (
            <div class="print-abstract">
              <div class="print-abstract-label">Abstract</div>
              <p>{issue.data.summary}</p>
            </div>
          )}
        </section>
      )}

      <!-- ═════ Sections ═════ -->
      {sections.map((section, i) => {
        const { Content } = rendered[i];
        const marker = section.data.section_marker ?? `§ ${section.data.section_number}`;
        const isForeword = section.data.section_number === 0;
        return (
          <section
            class={`print-chapter ${isForeword ? 'is-foreword' : 'is-body'}`}
            id={`s-${section.data.section_number}`}
          >
            <header class="print-chapter-head">
              <span class="print-chapter-marker">{marker}</span>
              <h2 class="print-chapter-title">{section.data.title}</h2>
              {section.data.summary && (
                <p class="print-chapter-dek">{section.data.summary}</p>
              )}
            </header>

            {section.data.pull_quote && !isForeword && (
              <aside class="print-pullquote">{section.data.pull_quote}</aside>
            )}

            <div class="print-chapter-body">
              <Content />
            </div>

            <div class="print-chapter-end">§</div>
          </section>
        );
      })}

      <!-- ═════ Colophon ═════ -->
      <section class="print-colophon">
        <h3>Colophon.</h3>
        <div class="print-bar"><div></div><div></div><div></div></div>
        <dl>
          <dt>Issue</dt>
          <dd>{verticalUp} No. {issueNumPadded} · {publishedString}<br/>{issue.data.issue_title}</dd>
          <dt>Published by</dt>
          <dd>TheFocus.AI Press, Cornwall, Connecticut</dd>
          <dt>Set in</dt>
          <dd>Fraunces, Newsreader, and {vertical === 'runtime' || vertical === 'harness' ? 'JetBrains Mono' : 'IBM Plex Mono'}.</dd>
          <dt>Voice</dt>
          <dd>{issue.data.voice === 'reportage' ? 'Reportage · first-person allowed' : 'Architecture · third-person, cited'}</dd>
        </dl>
        <p class="print-fin">— fin —</p>
      </section>

    </div>

    <style is:global>
      /* ═════ Per-vertical theme tokens ═════ */
      [data-mag='state'] {
        --mag-paper: #ece4cc; --mag-paper-2: #e2d9ba;
        --mag-ink: #141310; --mag-ink-soft: #2a2721; --mag-ink-mute: #6b6256;
        --mag-accent: #c2492a; --mag-accent-deep: #9c3a20; --mag-spot: #2d4f56;
      }
      [data-mag='surface'] {
        --mag-paper: #f2ecde; --mag-paper-2: #e8e0cc;
        --mag-ink: #141310; --mag-ink-soft: #2a2721; --mag-ink-mute: #6b6256;
        --mag-accent: #c2492a; --mag-accent-deep: #9c3a20; --mag-spot: #2d4f56;
      }
      [data-mag='runtime'] {
        --mag-paper: #f0e6d2; --mag-paper-2: #e8dcc4;
        --mag-ink: #1a1410; --mag-ink-soft: #3d3328; --mag-ink-mute: #8a7a64;
        --mag-accent: #c73e1d; --mag-accent-deep: #9c2d12; --mag-spot: #5a6b3e;
      }
      [data-mag='harness'] {
        --mag-paper: #e8dfc2; --mag-paper-2: #ddd2af;
        --mag-ink: #141310; --mag-ink-soft: #2a2721; --mag-ink-mute: #6b6256;
        --mag-accent: #8b4513; --mag-accent-deep: #5a2d0c; --mag-spot: #2d5a3d;
      }
      [data-mag='local'] {
        --mag-paper: #ebe2c7; --mag-paper-2: #dbd0ad;
        --mag-ink: #141310; --mag-ink-soft: #2a2721; --mag-ink-mute: #6b6256;
        --mag-accent: #b82020; --mag-accent-deep: #7a1515; --mag-spot: #3d2a6b;
      }
      [data-mag='wire'] {
        --mag-paper: #efe4c8; --mag-paper-2: #e4d7b4;
        --mag-ink: #141310; --mag-ink-soft: #2a2721; --mag-ink-mute: #6b6256;
        --mag-accent: #a65a1c; --mag-accent-deep: #6d3a10; --mag-spot: #1d3a40;
      }

      /* ═════ Paged Media rules ═════ */
      @page {
        size: 7in 10in;            /* magazine trim */
        margin: 0.8in 0.7in 1in 0.7in;

        @top-left {
          content: string(issue-label);
          font-family: 'IBM Plex Mono', monospace;
          font-size: 8pt;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          color: #6b6256;
        }
        @top-right {
          content: string(chapter-title);
          font-family: 'Newsreader', serif;
          font-style: italic;
          font-size: 9pt;
          color: #2a2721;
        }
        @bottom-center {
          content: counter(page);
          font-family: 'IBM Plex Mono', monospace;
          font-size: 9pt;
          color: #6b6256;
        }
      }

      @page :first {
        margin: 0;
        @top-left { content: none; }
        @top-right { content: none; }
        @bottom-center { content: none; }
      }

      @page toc-page {
        @top-left { content: string(issue-label); }
        @top-right { content: 'Contents'; }
      }
      @page cover-page {
        margin: 0;
        @top-left { content: none; }
        @top-right { content: none; }
        @bottom-center { content: none; }
      }

      /* ═════ Body base ═════ */
      html, body {
        margin: 0;
        padding: 0;
        font-family: 'Newsreader', serif;
        font-size: 10.5pt;
        line-height: 1.55;
        color: #141310;
      }
      body::before { display: none; } /* kill the paper grain in print */
      * { box-sizing: border-box; }

      /* Set issue label string once for running header */
      .print-body {
        string-set: issue-label '';
      }
      .print-cover { string-set: issue-label ''; page: cover-page; }
      .print-toc { page: toc-page; string-set: issue-label attr(data-issue-label, string, ''); }

      .print-chapter {
        string-set: chapter-title attr(data-chapter, string, '');
        break-before: page;
      }

      /* ═════ Cover ═════ */
      .print-cover {
        background: var(--mag-paper);
        padding: 0.9in 0.85in;
        height: 10in;
        width: 7in;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        break-after: page;
      }
      .print-cover-top {
        display: flex;
        justify-content: space-between;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 8pt;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #2a2721;
        line-height: 1.55;
      }
      .print-cover-number { text-align: right; }
      .print-cover-masthead {
        font-family: 'Fraunces', serif;
        font-variation-settings: 'opsz' 144, 'SOFT' 0, 'wght' 600;
        font-size: 96pt;
        line-height: 0.82;
        letter-spacing: -0.045em;
        color: var(--mag-ink);
        margin: 0.2in 0 0;
      }
      .print-cover-masthead .period {
        color: var(--mag-accent);
        font-variation-settings: 'opsz' 144, 'SOFT' 100, 'wght' 600;
      }
      .print-cover-emblem {
        align-self: center;
        width: 80%;
        max-width: 4.5in;
        margin: 0.2in 0;
      }
      .print-cover-emblem svg { width: 100%; height: auto; }
      .print-cover-lines { margin-top: auto; }
      .print-cover-kicker {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 8pt;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--mag-accent);
        margin: 0 0 8pt;
      }
      .print-cover-subtitle {
        font-family: 'Fraunces', serif;
        font-variation-settings: 'opsz' 144, 'SOFT' 30, 'wght' 400;
        font-style: italic;
        font-size: 36pt;
        line-height: 0.98;
        letter-spacing: -0.025em;
        margin: 0 0 12pt;
        color: var(--mag-ink);
      }
      .print-cover-dek {
        font-family: 'Newsreader', serif;
        font-size: 12pt;
        line-height: 1.4;
        color: #2a2721;
        margin: 0 0 14pt;
        max-width: 4.5in;
        font-weight: 300;
      }
      .print-cover-tagline {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 13pt;
        line-height: 1.35;
        color: var(--mag-spot);
        margin: 0;
        padding-left: 12pt;
        border-left: 2pt solid var(--mag-accent);
        max-width: 4.5in;
      }
      .print-cover-footer {
        margin-top: 0.35in;
        padding-top: 10pt;
        border-top: 0.5pt solid rgba(20,19,16,0.25);
        display: flex;
        justify-content: space-between;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 8pt;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #2a2721;
      }

      /* ═════ TOC ═════ */
      .print-toc {
        break-after: page;
        padding-top: 0.1in;
      }
      .print-toc-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 8pt;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--mag-accent);
        margin-bottom: 0.25in;
        padding-bottom: 10pt;
        border-bottom: 2pt solid var(--mag-ink);
      }
      .print-toc h2 {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-weight: 400;
        font-size: 32pt;
        line-height: 1;
        margin: 0 0 0.35in;
        color: var(--mag-ink);
      }
      .print-toc-list {
        list-style: none;
        padding: 0;
        margin: 0 0 0.3in;
      }
      .print-toc-list li {
        display: grid;
        grid-template-columns: 48pt 1fr;
        gap: 12pt;
        padding: 8pt 0;
        border-bottom: 0.5pt solid rgba(20,19,16,0.2);
      }
      .print-toc-list .num {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 9pt;
        letter-spacing: 0.08em;
        color: var(--mag-accent);
        font-weight: 600;
      }
      .print-toc-list .title {
        font-family: 'Fraunces', serif;
        font-size: 14pt;
        line-height: 1.25;
        letter-spacing: -0.01em;
      }
      .print-toc-list .title em {
        display: block;
        font-size: 10pt;
        color: #6b6256;
        font-style: italic;
        margin-top: 2pt;
      }
      .print-toc-list .page {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 9pt;
        color: #6b6256;
      }
      .print-toc-list .page a {
        color: inherit;
        text-decoration: none;
      }
      .print-toc-list .page a::after {
        content: target-counter(attr(href), page);
      }
      .print-abstract {
        margin-top: 0.35in;
        padding-top: 14pt;
        border-top: 0.5pt solid rgba(20,19,16,0.2);
      }
      .print-abstract-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 8pt;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--mag-accent);
        margin-bottom: 8pt;
      }
      .print-abstract p {
        font-family: 'Newsreader', serif;
        font-size: 11pt;
        line-height: 1.55;
        margin: 0;
      }

      /* ═════ Chapter ═════ */
      .print-chapter {
        padding-top: 0.1in;
      }
      .print-chapter-head {
        border-bottom: 1.5pt solid var(--mag-ink);
        padding-bottom: 14pt;
        margin-bottom: 20pt;
        position: relative;
      }
      .print-chapter-head::after {
        content: '';
        position: absolute;
        bottom: -4pt;
        left: 0;
        width: 36pt;
        height: 6pt;
        background: var(--mag-accent);
      }
      .print-chapter-marker {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 9pt;
        letter-spacing: 0.18em;
        color: var(--mag-accent);
        font-weight: 600;
      }
      .print-chapter-title {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 30pt;
        line-height: 0.98;
        letter-spacing: -0.025em;
        margin: 6pt 0 8pt;
        color: var(--mag-ink);
      }
      .print-chapter-dek {
        font-family: 'Fraunces', serif;
        font-size: 13pt;
        line-height: 1.35;
        color: var(--mag-spot);
        margin: 0;
        max-width: 4.5in;
      }
      .print-pullquote {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 17pt;
        line-height: 1.25;
        color: var(--mag-spot);
        margin: 16pt 0;
        padding: 10pt 0 10pt 14pt;
        border-left: 2pt solid var(--mag-accent);
        column-span: all;
        break-inside: avoid;
      }
      .print-chapter-body {
        column-count: 2;
        column-gap: 22pt;
        column-rule: 0.5pt solid rgba(20,19,16,0.18);
        orphans: 3;
        widows: 3;
      }
      .is-foreword .print-chapter-body {
        column-count: 1;
        max-width: 5in;
        margin: 0 auto;
        font-size: 11pt;
      }
      .print-chapter-body p {
        margin: 0 0 8pt;
        font-size: 10pt;
        line-height: 1.55;
      }
      .print-chapter-body p:first-of-type::first-letter {
        font-family: 'Fraunces', serif;
        font-variation-settings: 'opsz' 144, 'SOFT' 100, 'wght' 600;
        font-size: 48pt;
        float: left;
        line-height: 0.85;
        margin: 2pt 4pt 0 -2pt;
        color: var(--mag-accent);
      }
      .print-chapter-body h2 {
        font-family: 'Fraunces', serif;
        font-size: 16pt;
        margin: 16pt 0 8pt;
        column-span: all;
        padding-top: 10pt;
        border-top: 0.5pt solid rgba(20,19,16,0.2);
      }
      .print-chapter-body h3 {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 13pt;
        margin: 14pt 0 6pt;
        color: var(--mag-spot);
      }
      .print-chapter-body strong { font-weight: 700; }
      .print-chapter-body em { font-style: italic; }
      .print-chapter-body a {
        color: var(--mag-accent-deep);
        text-decoration: underline;
        text-decoration-thickness: 0.3pt;
      }
      .print-chapter-body code {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 8.5pt;
        background: var(--mag-paper-2);
        padding: 0 2pt;
      }
      .print-chapter-body figure {
        margin: 10pt 0;
        break-inside: avoid;
      }
      .print-chapter-body figure.figure-span {
        column-span: all;
        margin: 14pt 0;
      }
      .print-chapter-body figure img {
        width: 100%;
        height: auto;
        display: block;
      }
      .print-chapter-body figure figcaption {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 7pt;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #6b6256;
        margin-top: 4pt;
        padding-top: 3pt;
        border-top: 0.5pt solid rgba(20,19,16,0.2);
        line-height: 1.45;
      }
      .print-chapter-body blockquote {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 12pt;
        line-height: 1.3;
        color: var(--mag-spot);
        margin: 10pt 0;
        padding: 4pt 0 4pt 10pt;
        border-left: 2pt solid var(--mag-accent);
        break-inside: avoid;
      }
      .print-chapter-end {
        text-align: right;
        margin-top: 20pt;
        color: var(--mag-accent);
        font-family: 'Fraunces', serif;
        font-size: 14pt;
        font-style: italic;
      }

      /* ═════ Colophon ═════ */
      .print-colophon {
        break-before: page;
        padding-top: 0.3in;
      }
      .print-colophon h3 {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 20pt;
        margin: 0 0 10pt;
      }
      .print-bar {
        height: 14pt;
        display: flex;
        margin: 8pt 0 20pt;
      }
      .print-bar div:nth-child(1) { flex: 3; background: var(--mag-accent); }
      .print-bar div:nth-child(2) { flex: 2; background: var(--mag-spot); }
      .print-bar div:nth-child(3) { flex: 1; background: var(--mag-ink); }
      .print-colophon dl {
        display: grid;
        grid-template-columns: 1in 1fr;
        gap: 8pt 14pt;
        font-size: 9pt;
      }
      .print-colophon dt {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 8pt;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #6b6256;
        font-weight: 500;
      }
      .print-colophon dd {
        margin: 0;
        font-family: 'Newsreader', serif;
      }
      .print-fin {
        margin-top: 0.35in;
        text-align: center;
        font-family: 'Fraunces', serif;
        font-style: italic;
        color: var(--mag-spot);
      }

      /* ═════ Paged.js preview chrome (screen only, so we can see what the PDF will look like) ═════ */
      .pagedjs_pages {
        background: #d0cec4;
        padding: 16px 0;
      }
      .pagedjs_page {
        background: var(--mag-paper);
        box-shadow: 0 6px 18px rgba(0,0,0,0.18);
        margin: 10px auto;
      }
    </style>
  </body>
</html>
