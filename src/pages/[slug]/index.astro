---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CoverEmblem from '../../components/CoverEmblem.astro';
import '../../styles/magazine.css';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map((issue) => ({
    params: { slug: issue.slug },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const { Content } = await issue.render();

const allSections = await getCollection('sections');
const sections = allSections
  .filter((s) => s.data.issue === issue.slug)
  .sort((a, b) => a.data.section_number - b.data.section_number);

const verticalLabel: Record<string, string> = {
  state: 'State',
  surface: 'Surface',
  runtime: 'Runtime',
  harness: 'Harness',
  local: 'Local',
  wire: 'Wire',
};

// Per-vertical sub-identity
const imprint: Record<string, { quarterly: string; lineage: string }> = {
  state: { quarterly: 'A Dispatch on the State of AI Engineering · Est. 2026', lineage: 'WMB · The Miami Dispatch' },
  surface: { quarterly: 'A Quarterly on Agentic Interfaces · Est. 2026', lineage: 'WMB · The Touring Post' },
  runtime: { quarterly: 'A Quarterly on AI Engineering Runtimes · Est. 2026', lineage: 'WMB · The Code-Mode Broadside' },
  harness: { quarterly: "A Builder's Field Manual · Est. 2026", lineage: 'WMB · The Gen-3 Dispatch' },
  local: { quarterly: "A Tract on Inference You Own · Est. 2026", lineage: 'WMB · The Local Counter' },
  wire: { quarterly: 'A Quarterly on Agent Interfaces & Protocols · Est. 2026', lineage: 'WMB · The Wire-Room' },
};

const publishedString = issue.data.published
  .toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  .toUpperCase();

const issueNumRoman = (n: number) => ['', 'I', 'II', 'III', 'IV', 'V', 'VI'][n] || String(n);
const issueNumPadded = String(issue.data.issue_number).padStart(2, '0');
const vertical = issue.data.vertical;
const imp = imprint[vertical];
---
<BaseLayout title={`${verticalLabel[vertical].toUpperCase()} № ${issueNumPadded} · ${issue.data.issue_title}`}>
  <div data-mag={vertical} class="mag-root">
    <div class="mag">

      <!-- ═══════════ COVER ═══════════ -->
      <section class="cover">
        <header class="cover-header">
          <div>Focus.AI Press<br/>Cornwall, Connecticut</div>
          <div class="issue">Issue No. {issueNumPadded}<br/>{publishedString}</div>
        </header>

        <div class="masthead">
          {verticalLabel[vertical]}<span class="period">.</span>
        </div>
        <div class="cover-tagline">{imp.quarterly}</div>

        <div class="cover-middle">
          <CoverEmblem vertical={vertical} />
        </div>

        <div class="cover-lines">
          <div class="cover-kicker">
            {issue.data.draft ? 'Preview · Forthcoming' : `The Feature · In ${sections.length || 'Several'} Chapters`}
          </div>
          <h1 class="cover-title">{issue.data.issue_title}</h1>
          <p class="cover-dek">{issue.data.subtitle}</p>
          {sections.length > 0 && (
            <p class="cover-cta">
              <a href={`/${issue.slug}/read/`} class="cover-cta-link">
                Read the full issue →
              </a>
            </p>
          )}
        </div>

        <footer class="cover-footer">
          <div>{verticalLabel[vertical].slice(0, 3).toUpperCase()}—{issueNumPadded}</div>
          <div>{imp.lineage}</div>
          <div>{issue.data.draft ? 'DRAFT' : '$0.00'}</div>
        </footer>
      </section>

      <!-- ═══════════ CONTENTS ═══════════ -->
      {sections.length > 0 && (
        <section class="contents">
          <div class="section-label">Contents · {publishedString}</div>
          <h2>In this issue.</h2>
          <ol class="toc">
            {sections.map((section, i) => {
              const pageNum = 1 + i * 5;
              return (
                <li aria-disabled={section.data.draft ? 'true' : 'false'}>
                  <a href={`/${issue.slug}/read/#s-${section.data.section_number}`}>
                    <span class="num">
                      {section.data.section_marker ?? `§${issueNumRoman(section.data.section_number)}`}
                    </span>
                    <span class="title">
                      {section.data.title}
                      {section.data.summary && <em>{section.data.summary.slice(0, 70)}{section.data.summary.length > 70 ? '…' : ''}</em>}
                    </span>
                    <span class="page">p. {String(pageNum).padStart(2, '0')}</span>
                  </a>
                </li>
              );
            })}
          </ol>
        </section>
      )}

      <!-- ═══════════ EDITOR'S NOTE / COVER BODY ═══════════ -->
      <section class="foreword">
        <div class="foreword-byline">From the Editor · {publishedString}</div>
        <h2>{issue.data.tagline}</h2>
        {issue.data.summary && <p>{issue.data.summary}</p>}
        <div class="mag-prose">
          <Content />
        </div>
        <div class="sig">— {verticalLabel[vertical]} Editorial</div>
      </section>

      <!-- ═══════════ CROSS-REFS ═══════════ -->
      {issue.data.cross_refs && issue.data.cross_refs.length > 0 && (
        <section class="xrefs">
          <div class="section-label">Cross-References</div>
          <ul class="xref-list">
            {issue.data.cross_refs.map((ref) => (
              <li>
                <a href={`/${ref.vertical}-${String(ref.issue).padStart(2, '0')}/`} class="xref-link">
                  <span class="xref-vertical">
                    {verticalLabel[ref.vertical]} · №&nbsp;{String(ref.issue).padStart(2, '0')}
                  </span>
                  <span class="xref-reason">{ref.reason}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- ═══════════ COLOPHON ═══════════ -->
      <footer class="colophon">
        <h3>Colophon.</h3>
        <div class="bar"><div></div><div></div><div></div></div>
        <div class="colophon-grid">
          <div class="item">
            <strong>Issue</strong>
            No. {issueNumPadded} · {publishedString}<br/>
            {issue.data.issue_title}
          </div>
          <div class="item">
            <strong>Published</strong>
            Focus.AI Press<br/>
            Cornwall, Connecticut
          </div>
          <div class="item">
            <strong>Set in</strong>
            Fraunces (David Jonathan Ross)<br/>
            Newsreader (Production Type)<br/>
            {vertical === 'runtime' || vertical === 'harness' ? 'JetBrains Mono' : 'IBM Plex Mono'}
          </div>
          <div class="item">
            <strong>Voice</strong>
            {issue.data.voice === 'reportage' ? 'Reportage · First-person allowed' : 'Architecture · Third-person, cited'}
          </div>
        </div>

        <p class="fine-print">
          {verticalLabel[vertical].toUpperCase()} is part of the Focus.AI Magazines.
          Contents reflect the state of the public record as of {publishedString.toLowerCase().replace(/^./, c => c.toUpperCase())}
          and should not be taken for engineering advice.
        </p>

        <nav class="back-nav">
          <a href="/" class="back-to-issues">← All issues</a>
        </nav>

        <p class="fin">— fin —</p>
      </footer>

    </div>
  </div>

  <style>
    .mag-root {
      position: relative;
    }

    .mag-prose :global(p) {
      font-size: 18px;
      line-height: 1.65;
      margin: 0 0 1.1em;
      font-weight: 380;
    }
    .mag-prose :global(ul), .mag-prose :global(ol) {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 13px;
      letter-spacing: 0.05em;
      list-style: none;
      padding: 16px 0 0;
      margin: 24px 0 16px;
      border-top: 1px solid var(--mag-rule);
      line-height: 2.1;
      color: var(--mag-ink-soft);
      text-transform: uppercase;
    }
    .mag-prose :global(li::before) {
      content: '§ ';
      color: var(--mag-accent);
      font-weight: 700;
      margin-right: 0.4em;
    }
    .mag-prose :global(a) {
      color: var(--mag-accent-deep);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }

    .xrefs {
      padding: 60px 0 40px;
      border-top: 1px solid var(--mag-rule);
    }

    .xref-list {
      list-style: none;
      padding: 0;
      margin: 16px 0 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .xref-link {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 24px;
      align-items: baseline;
      padding: 16px 20px;
      background: var(--mag-paper-2);
      border-left: 4px solid var(--mag-accent);
      text-decoration: none;
      color: var(--mag-ink);
      transition: transform 180ms ease;
    }

    .xref-link:hover { transform: translateX(3px); }

    .xref-vertical {
      font-family: var(--mag-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--mag-spot);
      font-weight: 700;
    }

    .xref-reason {
      font-family: var(--mag-body);
      font-size: 15px;
      line-height: 1.5;
      color: var(--mag-ink);
    }

    .back-nav {
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px dashed var(--mag-rule);
    }

    .fine-print {
      margin-top: 32px;
      font-size: 11px;
      color: var(--mag-ink-mute);
      max-width: 540px;
      line-height: 1.6;
    }

    .fin {
      margin-top: 24px;
      font-family: var(--mag-display);
      font-style: italic;
      font-size: 14px;
      color: var(--mag-spot);
      text-align: center;
    }

    .cover-cta {
      margin: 28px 0 0;
    }
    .cover-cta-link {
      display: inline-block;
      font-family: var(--mag-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--mag-ink);
      background: transparent;
      border: 1px solid var(--mag-ink);
      padding: 12px 20px;
      text-decoration: none;
      transition: background 180ms ease, color 180ms ease;
    }
    .cover-cta-link:hover {
      background: var(--mag-ink);
      color: var(--mag-paper);
    }

    @media (max-width: 640px) {
      .xref-link {
        grid-template-columns: 1fr;
        gap: 4px;
      }
    }
  </style>
</BaseLayout>
