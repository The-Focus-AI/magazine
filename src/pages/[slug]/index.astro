---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map((issue) => ({
    params: { slug: issue.slug },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const { Content } = await issue.render();

const allSections = await getCollection('sections');
const sections = allSections
  .filter((s) => s.data.issue === issue.slug)
  .sort((a, b) => a.data.section_number - b.data.section_number);

const verticalLabel = {
  state: 'STATE',
  surface: 'SURFACE',
  runtime: 'RUNTIME',
  harness: 'HARNESS',
  local: 'LOCAL',
  wire: 'WIRE',
};

const publishedString = issue.data.published.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});
---
<BaseLayout title={`${verticalLabel[issue.data.vertical]} № ${issue.data.issue_number} · ${issue.data.issue_title}`}>
  <article class="issue-cover" style={`--accent: ${issue.data.cover_color ?? '#c4563c'};`}>
    <div class="masthead">
      <span class="vertical">{verticalLabel[issue.data.vertical]}</span>
      <span class="divider">·</span>
      <span class="issue-number">Issue № {String(issue.data.issue_number).padStart(2, '0')}</span>
      <span class="divider">·</span>
      <span class="published">{publishedString}</span>
      {issue.data.draft && <span class="draft">In progress</span>}
    </div>

    <h1>{issue.data.issue_title}</h1>
    <p class="subtitle">{issue.data.subtitle}</p>
    <p class="tagline">{issue.data.tagline}</p>

    <div class="cover-content">
      <Content />
    </div>

    {sections.length > 0 && (
      <section class="toc">
        <h2>Table of Contents</h2>
        <ol>
          {sections.map((section) => (
            <li>
              <a href={`/${issue.slug}/${section.slug.replace(`${issue.slug}-`, '')}/`}>
                <span class="marker">{section.data.section_marker ?? `§ ${section.data.section_number}`}</span>
                <span class="title">{section.data.title}</span>
              </a>
              <p class="section-summary">{section.data.summary}</p>
            </li>
          ))}
        </ol>
      </section>
    )}

    {issue.data.cross_refs && issue.data.cross_refs.length > 0 && (
      <section class="cross-refs">
        <h2>Cross-references</h2>
        <ul>
          {issue.data.cross_refs.map((ref) => (
            <li>
              <a href={`/${ref.vertical}-${String(ref.issue).padStart(2, '0')}/`}>
                <strong>{verticalLabel[ref.vertical]} № {String(ref.issue).padStart(2, '0')}</strong>
              </a>
              — {ref.reason}
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>

  <style>
    .issue-cover {
      max-width: 760px;
      margin: 0 auto;
      padding: 4rem 3rem 6rem;
    }

    .masthead {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      font-family: var(--sans);
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 3rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--accent);
      flex-wrap: wrap;
    }

    .masthead .vertical {
      color: var(--accent);
      font-weight: 600;
    }

    .masthead .divider {
      color: var(--muted);
    }

    .draft {
      margin-left: auto;
      font-size: 0.7rem;
      padding: 0.2rem 0.5rem;
      background: var(--ink);
      color: var(--paper);
    }

    .issue-cover h1 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: clamp(2.5rem, 6vw, 4rem);
      line-height: 1;
      letter-spacing: -0.02em;
      margin: 0 0 1rem;
    }

    .issue-cover .subtitle {
      font-family: var(--serif);
      font-weight: 400;
      font-style: italic;
      font-size: 1.4rem;
      line-height: 1.3;
      color: var(--muted);
      margin: 0 0 2rem;
    }

    .issue-cover .tagline {
      font-family: var(--serif);
      font-size: 1.35rem;
      font-weight: 400;
      line-height: 1.4;
      margin: 0 0 3rem;
      padding-left: 1.5rem;
      border-left: 3px solid var(--accent);
    }

    .cover-content :global(p) {
      font-family: var(--serif);
      font-size: 1.15rem;
      line-height: 1.6;
      margin: 0 0 1.5rem;
    }

    .cover-content :global(ul),
    .cover-content :global(ol) {
      font-family: var(--serif);
      font-size: 1.1rem;
      line-height: 1.6;
    }

    .toc,
    .cross-refs {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--rule);
    }

    .toc h2,
    .cross-refs h2 {
      font-family: var(--sans);
      font-size: 0.8rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0 0 1.5rem;
      font-weight: 500;
    }

    .toc ol {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .toc li {
      padding: 1.25rem 0;
      border-bottom: 1px solid rgba(26, 26, 26, 0.12);
    }

    .toc li:last-child {
      border-bottom: none;
    }

    .toc a {
      display: flex;
      gap: 1rem;
      align-items: baseline;
      text-decoration: none;
    }

    .toc .marker {
      font-family: var(--sans);
      font-size: 0.85rem;
      color: var(--accent);
      min-width: 90px;
      font-weight: 500;
      letter-spacing: 0.02em;
    }

    .toc .title {
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 400;
      line-height: 1.3;
      flex: 1;
    }

    .toc a:hover .title {
      color: var(--accent);
    }

    .section-summary {
      font-family: var(--serif);
      font-size: 1rem;
      font-style: italic;
      color: var(--muted);
      margin: 0.5rem 0 0 calc(90px + 1rem);
      line-height: 1.5;
    }

    .cross-refs ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .cross-refs li {
      padding: 0.75rem 0;
      font-family: var(--serif);
      font-size: 1rem;
      line-height: 1.5;
    }

    @media (max-width: 640px) {
      .issue-cover {
        padding: 2rem 1.5rem 4rem;
      }

      .section-summary {
        margin-left: 0;
      }
    }
  </style>
</BaseLayout>
