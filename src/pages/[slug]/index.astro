---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CoverEmblem from '../../components/CoverEmblem.astro';
import EmailSignup from '../../components/EmailSignup.astro';
import '../../styles/magazine.css';

export async function getStaticPaths() {
  const issues = (await getCollection('issues')).filter((i) => !i.data.draft);
  return issues.map((issue) => ({
    params: { slug: issue.slug },
    props: { issue },
  }));
}

const { issue } = Astro.props;

const allSections = await getCollection('sections');
const sections = allSections
  .filter((s) => s.data.issue === issue.slug)
  .sort((a, b) => a.data.section_number - b.data.section_number);

const rendered = await Promise.all(sections.map((s) => s.render()));

const verticalLabel: Record<string, string> = {
  state: 'State',
  surface: 'Surface',
  runtime: 'Runtime',
  harness: 'Harness',
  local: 'Local',
  wire: 'Wire',
};

const imprint: Record<string, { quarterly: string; lineage: string }> = {
  state: { quarterly: 'A Dispatch on the State of AI Engineering · Est. 2026', lineage: 'WMB · The Miami Dispatch' },
  surface: { quarterly: 'A Quarterly on Agentic Interfaces · Est. 2026', lineage: 'WMB · The Touring Post' },
  runtime: { quarterly: 'A Quarterly on AI Engineering Runtimes · Est. 2026', lineage: 'WMB · The Code-Mode Broadside' },
  harness: { quarterly: "A Builder's Field Manual · Est. 2026", lineage: 'WMB · The Gen-3 Dispatch' },
  local: { quarterly: "A Tract on Inference You Own · Est. 2026", lineage: 'WMB · The Local Counter' },
  wire: { quarterly: 'A Quarterly on Agent Interfaces & Protocols · Est. 2026', lineage: 'WMB · The Wire-Room' },
};

const publishedString = issue.data.published
  .toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  .toUpperCase();

const issueNumPadded = String(issue.data.issue_number).padStart(2, '0');
const vertical = issue.data.vertical;
const verticalUp = verticalLabel[vertical].toUpperCase();
const imp = imprint[vertical];
---
<BaseLayout title={`${verticalUp} № ${issueNumPadded} · ${issue.data.issue_title}`}>
  <div data-mag={vertical} class="mag-root">

    <!-- ═══════════ COVER ═══════════ -->
    <div class="mag cover-wrap">
      <section class="cover">
        <header class="cover-header">
          <div>TheFocus.AI Press<br/>Cornwall, Connecticut</div>
          <div class="issue">Issue No. {issueNumPadded}<br/>{publishedString}</div>
        </header>

        <div class="masthead">
          {verticalLabel[vertical]}<span class="period">.</span>
        </div>
        <div class="cover-tagline">{imp.quarterly}</div>

        <div class="cover-middle">
          <CoverEmblem vertical={vertical} />
        </div>

        <div class="cover-lines">
          <div class="cover-kicker">
            {sections.length > 0 ? `The Feature · In ${sections.length} Chapters` : 'The Feature'}
          </div>
          <h1 class="cover-title">{issue.data.issue_title}</h1>
          <p class="cover-dek">{issue.data.subtitle}</p>
          <p class="cover-cta-hint">
            <a href="#contents">↓ Begin reading</a>
          </p>
        </div>

        <footer class="cover-footer">
          <div>{verticalLabel[vertical].slice(0, 3).toUpperCase()}—{issueNumPadded}</div>
          <div>{imp.lineage}</div>
          <div>$0.00</div>
        </footer>
      </section>
    </div>

    <article class="read">

      <!-- ═════ Opening spread — Contents ═════ -->
      <section class="read-opener" id="contents">
        <div class="opener-meta">
          <span>{verticalUp}&nbsp;·&nbsp;Issue No.&nbsp;{issueNumPadded}</span>
          <span>{publishedString}</span>
        </div>

        {issue.data.summary && (
          <div class="opener-abstract">
            <div class="abstract-label">Abstract</div>
            <p>{issue.data.summary}</p>
          </div>
        )}

        {sections.length > 0 && (
          <ol class="inline-toc">
            {sections.map((section) => {
              const marker = section.data.section_marker ?? `§ ${section.data.section_number}`;
              return (
                <li>
                  <a href={`#s-${section.data.section_number}`}>
                    <span class="toc-num">{marker}</span>
                    <span class="toc-title">{section.data.title}</span>
                  </a>
                </li>
              );
            })}
          </ol>
        )}
      </section>

      <!-- ═════ Sections, flowed ═════ -->
      {sections.map((section, i) => {
        const { Content } = rendered[i];
        const marker = section.data.section_marker ?? `§ ${section.data.section_number}`;
        const isForeword = section.data.section_number === 0;
        return (
          <section
            class={`read-section ${isForeword ? 'is-foreword' : 'is-chapter'}`}
            id={`s-${section.data.section_number}`}
          >
            <header class="read-section-head">
              <span class="read-section-marker">{marker}</span>
              <div class="read-section-titleblock">
                <h2 class="read-section-title">{section.data.title}</h2>
                {section.data.summary && (
                  <p class="read-section-dek">{section.data.summary}</p>
                )}
              </div>
              <span class="read-section-folio">
                {verticalUp} · № {issueNumPadded}
              </span>
            </header>

            {section.data.pull_quote && !isForeword && (
              <aside class="read-pullquote">{section.data.pull_quote}</aside>
            )}

            <div class="read-section-body">
              <Content />
            </div>

            <div class="read-section-end">§</div>
          </section>
        );
      })}

      <!-- ═════ Newsletter ═════ -->
      <EmailSignup
        variant="magazine"
        heading="Stay close to the next issue."
        blurb="STATE drops irregularly. Get notified when the next dispatch lands."
      />

      <!-- ═════ Closing ═════ -->
      <footer class="read-closer">
        <div class="bar"><div></div><div></div><div></div></div>
        <p class="closer-lede">
          {verticalUp} · № {issueNumPadded} · <em>{issue.data.issue_title}</em>
        </p>
        <p class="closer-fine">
          Published by TheFocus.AI Press, Cornwall, Connecticut, {publishedString}.
          Set in Fraunces, Newsreader, and {vertical === 'runtime' || vertical === 'harness' ? 'JetBrains Mono' : 'IBM Plex Mono'}.
          Contents reflect the state of the public record as of press.
        </p>
        <p class="closer-nav">
          <a href="/">← All issues</a>
        </p>
        <p class="closer-fin">— fin —</p>
      </footer>

    </article>

  </div>

  <style>
    .mag-root { position: relative; }

    /* Match cover width to article width below */
    .cover-wrap {
      max-width: 920px;
      padding: 0 48px;
    }

    /* ═════ Cover hero hint ═════ */
    .cover-cta-hint {
      margin: 28px 0 0;
      font-family: var(--mag-mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .cover-cta-hint a {
      color: var(--mag-accent-deep);
      text-decoration: none;
      border-bottom: 1px solid currentColor;
      padding-bottom: 2px;
      transition: color 150ms ease;
    }
    .cover-cta-hint a:hover {
      color: var(--mag-spot);
    }

    /* ═════ Article ═════ */
    .read {
      max-width: 920px;
      margin: 0 auto;
      padding: 72px 48px 100px;
      position: relative;
      z-index: 2;
    }

    /* ═════ Opener ═════ */
    .read-opener {
      margin-bottom: 80px;
      padding-top: 24px;
    }
    .opener-meta {
      display: flex;
      justify-content: space-between;
      font-family: var(--mag-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--mag-ink-soft);
      padding-bottom: 16px;
      border-bottom: 1px solid var(--mag-ink);
      margin-bottom: 32px;
    }
    .opener-abstract { max-width: 680px; }
    .abstract-label {
      font-family: var(--mag-mono);
      font-size: 10px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--mag-accent);
      margin-bottom: 16px;
    }
    .opener-abstract p {
      font-family: var(--mag-body);
      font-size: 20px;
      line-height: 1.55;
      color: var(--mag-ink);
      margin: 0;
      font-weight: 380;
    }

    /* Inline TOC inside opener */
    .inline-toc {
      list-style: none;
      padding: 0;
      margin: 56px 0 64px;
      border-top: 1px solid var(--mag-ink);
      max-width: 720px;
    }
    .inline-toc li {
      border-bottom: 1px solid var(--mag-rule);
    }
    .inline-toc a {
      display: grid;
      grid-template-columns: 60px 1fr;
      gap: 18px;
      align-items: baseline;
      padding: 14px 4px;
      text-decoration: none;
      color: var(--mag-ink);
      transition: padding 150ms ease, color 150ms ease;
    }
    .inline-toc a:hover {
      padding-left: 12px;
      color: var(--mag-accent);
    }
    .toc-num {
      font-family: var(--mag-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      color: var(--mag-accent);
      font-weight: 700;
    }
    .toc-title {
      font-family: var(--mag-display);
      font-size: 19px;
      letter-spacing: -0.01em;
      font-style: italic;
    }

    /* ═════ Sections ═════ */
    .read-section {
      margin: 96px 0;
      padding-top: 48px;
      border-top: 1px solid var(--mag-rule);
    }
    .read-section-head {
      display: grid;
      grid-template-columns: 80px 1fr 120px;
      gap: 24px;
      align-items: baseline;
      padding-bottom: 28px;
      margin-bottom: 36px;
      border-bottom: 2px solid var(--mag-ink);
      position: relative;
    }
    .read-section-head::after {
      content: '';
      position: absolute;
      bottom: -6px;
      left: 0;
      width: 56px;
      height: 10px;
      background: var(--mag-accent);
    }
    .read-section-marker {
      font-family: var(--mag-mono);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--mag-accent);
    }
    .read-section-title {
      font-family: var(--mag-display);
      font-variation-settings: 'opsz' 144, 'SOFT' 20, 'wght' 400;
      font-size: clamp(40px, 5.5vw, 68px);
      line-height: 0.98;
      letter-spacing: -0.025em;
      font-style: italic;
      margin: 0 0 12px;
      color: var(--mag-ink);
    }
    .read-section-dek {
      font-family: var(--mag-display);
      font-variation-settings: 'opsz' 36, 'SOFT' 0, 'wght' 400;
      font-size: 19px;
      line-height: 1.4;
      color: var(--mag-spot);
      margin: 0;
      max-width: 640px;
    }
    .read-section-folio {
      font-family: var(--mag-mono);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--mag-ink-mute);
      text-align: right;
    }

    .read-pullquote {
      font-family: var(--mag-display);
      font-variation-settings: 'opsz' 144, 'SOFT' 40, 'wght' 300;
      font-size: 30px;
      line-height: 1.2;
      letter-spacing: -0.015em;
      color: var(--mag-spot);
      font-style: italic;
      margin: 28px auto 36px;
      padding: 28px 0 28px 36px;
      border-left: 4px solid var(--mag-accent);
      max-width: 720px;
    }

    .read-section-body {
      column-count: 2;
      column-gap: 44px;
      column-rule: 1px solid var(--mag-rule);
      font-family: var(--mag-body);
      font-size: 17px;
      line-height: 1.65;
      font-weight: 380;
      orphans: 3;
      widows: 3;
    }
    .is-foreword .read-section-body {
      column-count: 1;
      max-width: 640px;
      font-size: 19px;
      line-height: 1.6;
    }

    .read-section-body :global(p) { margin: 0 0 1.1em; }
    .read-section-body :global(p:first-of-type::first-letter) {
      font-family: var(--mag-display);
      font-variation-settings: 'opsz' 144, 'SOFT' 100, 'wght' 600;
      font-size: 5.2em;
      float: left;
      line-height: 0.85;
      margin: 0.05em 0.1em 0 -0.04em;
      color: var(--mag-accent);
      font-style: normal;
    }
    .read-section-body :global(h2) {
      font-family: var(--mag-display);
      font-variation-settings: 'opsz' 72, 'SOFT' 20, 'wght' 600;
      font-size: 28px;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin: 40px 0 20px;
      color: var(--mag-ink);
      column-span: all;
      break-before: column;
      padding-top: 24px;
      border-top: 1px solid var(--mag-rule);
    }
    .read-section-body :global(h3) {
      font-family: var(--mag-display);
      font-style: italic;
      font-weight: 500;
      font-size: 22px;
      letter-spacing: -0.01em;
      margin: 32px 0 14px;
      color: var(--mag-spot);
    }
    .read-section-body :global(strong) { font-weight: 700; color: var(--mag-ink); }
    .read-section-body :global(em) { font-style: italic; }
    .read-section-body :global(a) {
      color: var(--mag-accent-deep);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    .read-section-body :global(a:hover) { color: var(--mag-spot); }
    .read-section-body :global(code) {
      font-family: var(--mag-mono);
      font-size: 0.88em;
      background: var(--mag-paper-2);
      padding: 0.08em 0.35em;
      border-radius: 2px;
    }
    .read-section-body :global(ul),
    .read-section-body :global(ol) {
      margin: 0 0 1.1em 1.2em;
      padding: 0;
    }
    .read-section-body :global(li) { margin: 0 0 0.4em; }
    .read-section-body :global(blockquote) {
      font-family: var(--mag-display);
      font-variation-settings: 'opsz' 72, 'SOFT' 40, 'wght' 300;
      font-size: 22px;
      line-height: 1.3;
      font-style: italic;
      color: var(--mag-spot);
      margin: 24px 0;
      padding: 0 0 0 20px;
      border-left: 3px solid var(--mag-accent);
      break-inside: avoid;
    }
    .read-section-body :global(figure) {
      margin: 28px 0;
      break-inside: avoid;
    }
    .read-section-body :global(figure.figure-span) {
      column-span: all;
      margin: 40px 0;
    }
    .read-section-body :global(figure img) {
      width: 100%;
      height: auto;
      display: block;
      border: 1px solid var(--mag-rule);
    }
    .read-section-body :global(figure figcaption) {
      font-family: var(--mag-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--mag-ink-mute);
      margin-top: 10px;
      padding-top: 8px;
      border-top: 1px solid var(--mag-rule);
      line-height: 1.5;
    }

    .read-section-end {
      text-align: right;
      margin-top: 40px;
      color: var(--mag-accent);
      font-family: var(--mag-display);
      font-size: 24px;
      font-style: italic;
    }

    /* ═════ Closer ═════ */
    .read-closer {
      margin-top: 120px;
      padding-top: 56px;
      border-top: 3px double var(--mag-ink);
      text-align: center;
    }
    .read-closer .bar {
      height: 20px;
      display: flex;
      margin: 0 auto 32px;
      max-width: 320px;
    }
    .read-closer .bar div:nth-child(1) { flex: 3; background: var(--mag-accent); }
    .read-closer .bar div:nth-child(2) { flex: 2; background: var(--mag-spot); }
    .read-closer .bar div:nth-child(3) { flex: 1; background: var(--mag-ink); }
    .closer-lede {
      font-family: var(--mag-display);
      font-style: italic;
      font-size: 20px;
      color: var(--mag-ink);
      margin: 0 0 16px;
    }
    .closer-fine {
      font-family: var(--mag-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--mag-ink-mute);
      line-height: 1.8;
      max-width: 520px;
      margin: 0 auto 32px;
    }
    .closer-nav {
      font-family: var(--mag-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin: 0 0 24px;
    }
    .closer-nav a {
      color: var(--mag-ink);
      text-decoration: none;
      border-bottom: 1px solid transparent;
    }
    .closer-nav a:hover {
      border-bottom-color: var(--mag-accent);
      color: var(--mag-accent);
    }
    .closer-fin {
      font-family: var(--mag-display);
      font-style: italic;
      font-size: 16px;
      color: var(--mag-spot);
      margin: 24px 0 0;
    }

    /* ═════ Responsive ═════ */
    @media (max-width: 900px) {
      .read { padding: 48px 24px 80px; }
      .read-section-head { grid-template-columns: 60px 1fr; }
      .read-section-folio { display: none; }
      .read-section-body {
        column-count: 1;
        column-rule: none;
      }
      .read-section-body :global(h2) { column-span: initial; }
      .inline-toc a {
        grid-template-columns: 50px 1fr;
        gap: 12px;
      }
    }

    @media print {
      .issue-toolbar,
      .site-header,
      .site-footer { display: none !important; }
      body { background: var(--mag-paper); }
      .read { max-width: none; padding: 0; }
      .read-section-body { font-size: 11pt; line-height: 1.45; }
      [data-mag]::before { display: none; }
    }
  </style>
</BaseLayout>
