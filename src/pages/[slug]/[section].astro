---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/magazine.css';

export async function getStaticPaths() {
  const sections = await getCollection('sections');
  return sections.map((section) => {
    const issueSlug = section.data.issue;
    const sectionSlug = section.slug.replace(`${issueSlug}-`, '');
    return {
      params: { slug: issueSlug, section: sectionSlug },
      props: { section },
    };
  });
}

const { section } = Astro.props;
const issue = await getEntry('issues', section.data.issue);
const { Content } = await section.render();

const allSections = await getCollection('sections');
const siblings = allSections
  .filter((s) => s.data.issue === section.data.issue)
  .sort((a, b) => a.data.section_number - b.data.section_number);

const currentIndex = siblings.findIndex((s) => s.slug === section.slug);
const prev = siblings[currentIndex - 1];
const next = siblings[currentIndex + 1];

const verticalLabel: Record<string, string> = {
  state: 'State',
  surface: 'Surface',
  runtime: 'Runtime',
  harness: 'Harness',
  local: 'Local',
  wire: 'Wire',
};

const issueUrlSlug = (s: any) => s.slug.replace(`${section.data.issue}-`, '');
const vertical = issue.data.vertical;
const issueNumPadded = String(issue.data.issue_number).padStart(2, '0');
const pageNum = String(currentIndex + 1).padStart(2, '0');

const sourceLines: string[] = [];
if (section.data.sources) {
  for (const src of section.data.sources) {
    sourceLines.push(`${src.type.toUpperCase()} · ${src.slug}`);
  }
}
---
<BaseLayout title={`${section.data.title} · ${verticalLabel[vertical]} № ${issueNumPadded}`}>
  <div data-mag={vertical} class="mag-root">
    <div class="mag">

      <article class="chapter" id={`ch${section.data.section_number}`}>
        <div class="chapter-head">
          <span class="chapter-num">{section.data.section_marker ?? `§ ${section.data.section_number}`}</span>
          <span class="chapter-kicker">
            {verticalLabel[vertical]} · № {issueNumPadded} · {issue.data.issue_title}
          </span>
        </div>

        <h1 class="chapter-title">{section.data.title}</h1>

        {section.data.summary && (
          <p class="chapter-subtitle">{section.data.summary}</p>
        )}

        {sourceLines.length > 0 && (
          <div class="chapter-meta">
            {sourceLines.map((line) => <span>{line}</span>)}
          </div>
        )}

        <div class="chapter-body">
          <Content />
        </div>

        {section.data.pull_quote && (
          <div class="pull">{section.data.pull_quote}</div>
        )}

        <div class="chapter-end">§</div>
      </article>

      {/* Prev / Issue / Next nav */}
      <nav class="section-nav">
        <div class="nav-prev">
          {prev ? (
            <a href={`/${section.data.issue}/${issueUrlSlug(prev)}/`}>
              ← {prev.data.section_marker ?? `§ ${prev.data.section_number}`} {prev.data.title}
            </a>
          ) : (
            <span>Cover</span>
          )}
        </div>
        <div class="nav-issue">
          <a href={`/${section.data.issue}/`}>
            {verticalLabel[vertical]} № {issueNumPadded}
          </a>
          <span class="nav-page">p. {pageNum} / {String(siblings.length).padStart(2, '0')}</span>
        </div>
        <div class="nav-next">
          {next ? (
            <a href={`/${section.data.issue}/${issueUrlSlug(next)}/`}>
              {next.data.section_marker ?? `§ ${next.data.section_number}`} {next.data.title} →
            </a>
          ) : (
            <a href={`/${section.data.issue}/`}>Back to issue →</a>
          )}
        </div>
      </nav>

      <div class="back-outer">
        <a href="/" class="back-to-issues">← All issues</a>
      </div>
    </div>
  </div>

  <style>
    .mag-root { position: relative; }

    .nav-page {
      display: block;
      margin-top: 4px;
      font-size: 9px;
      opacity: 0.65;
    }

    .back-outer {
      padding: 48px 0 80px;
      border-top: 1px dashed var(--mag-rule);
      margin-top: 40px;
      text-align: center;
    }
  </style>
</BaseLayout>
