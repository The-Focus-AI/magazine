---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const sections = await getCollection('sections');
  return sections.map((section) => {
    const [, ...rest] = section.slug.split('-');
    const issueSlug = section.data.issue;
    const sectionSlug = section.slug.replace(`${issueSlug}-`, '');
    return {
      params: { slug: issueSlug, section: sectionSlug },
      props: { section },
    };
  });
}

const { section } = Astro.props;
const issue = await getEntry('issues', section.data.issue);
const { Content } = await section.render();

const allSections = await getCollection('sections');
const siblings = allSections
  .filter((s) => s.data.issue === section.data.issue)
  .sort((a, b) => a.data.section_number - b.data.section_number);

const currentIndex = siblings.findIndex((s) => s.slug === section.slug);
const prev = siblings[currentIndex - 1];
const next = siblings[currentIndex + 1];

const verticalLabel = {
  state: 'STATE',
  surface: 'SURFACE',
  runtime: 'RUNTIME',
  harness: 'HARNESS',
  local: 'LOCAL',
  wire: 'WIRE',
};

const issueSlugForUrl = (s) => s.slug.replace(`${section.data.issue}-`, '');
---
<BaseLayout title={`${section.data.title} · ${issue?.data.issue_title}`}>
  <article class="section" style={`--accent: ${issue?.data.cover_color ?? '#c4563c'};`}>
    <nav class="breadcrumb">
      <a href="/">Issues</a>
      <span>/</span>
      <a href={`/${section.data.issue}/`}>
        {verticalLabel[issue?.data.vertical]} № {String(issue?.data.issue_number).padStart(2, '0')}
      </a>
      <span>/</span>
      <span>{section.data.section_marker ?? `§ ${section.data.section_number}`}</span>
    </nav>

    <header class="section-head">
      <div class="marker">{section.data.section_marker ?? `§ ${section.data.section_number}`}</div>
      <h1>{section.data.title}</h1>
      <p class="summary">{section.data.summary}</p>
    </header>

    {section.data.pull_quote && (
      <blockquote class="pull-quote">{section.data.pull_quote}</blockquote>
    )}

    <div class={`body voice-${issue?.data.voice}`}>
      <Content />
    </div>

    {section.data.sources && section.data.sources.length > 0 && (
      <aside class="sources">
        <h3>Sources</h3>
        <ul>
          {section.data.sources.map((source) => (
            <li>
              <span class="source-type">{source.type}</span>
              <code>{source.slug}</code>
            </li>
          ))}
        </ul>
      </aside>
    )}

    {section.data.concepts && section.data.concepts.length > 0 && (
      <aside class="concepts">
        <h3>Concepts</h3>
        <ul>
          {section.data.concepts.map((concept) => (
            <li><code>{concept}</code></li>
          ))}
        </ul>
      </aside>
    )}

    <nav class="section-nav">
      {prev && (
        <a class="nav-prev" href={`/${section.data.issue}/${issueSlugForUrl(prev)}/`}>
          <span class="label">Previous</span>
          <span class="title">← {prev.data.title}</span>
        </a>
      )}
      {next && (
        <a class="nav-next" href={`/${section.data.issue}/${issueSlugForUrl(next)}/`}>
          <span class="label">Next</span>
          <span class="title">{next.data.title} →</span>
        </a>
      )}
    </nav>
  </article>

  <style>
    .section {
      max-width: 720px;
      margin: 0 auto;
      padding: 2rem 3rem 6rem;
    }

    .breadcrumb {
      display: flex;
      gap: 0.5rem;
      font-family: var(--sans);
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 3rem;
      letter-spacing: 0.05em;
    }

    .breadcrumb a {
      color: var(--muted);
      text-decoration: none;
    }

    .breadcrumb a:hover {
      color: var(--accent);
    }

    .section-head {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }

    .section-head .marker {
      font-family: var(--sans);
      font-size: 0.85rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 500;
      margin-bottom: 0.5rem;
    }

    .section-head h1 {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(2rem, 5vw, 2.75rem);
      line-height: 1.1;
      letter-spacing: -0.01em;
      margin: 0 0 1rem;
    }

    .section-head .summary {
      font-family: var(--serif);
      font-size: 1.15rem;
      font-style: italic;
      color: var(--muted);
      margin: 0;
      line-height: 1.45;
    }

    .pull-quote {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 1.6rem;
      line-height: 1.3;
      margin: 2rem 0;
      padding: 0 2rem;
      border-left: 3px solid var(--accent);
      color: var(--ink);
    }

    .body :global(p) {
      font-family: var(--serif);
      font-size: 1.15rem;
      line-height: 1.65;
      margin: 0 0 1.5rem;
    }

    .body :global(h2),
    .body :global(h3),
    .body :global(h4) {
      font-family: var(--serif);
      font-weight: 500;
      margin: 2.5rem 0 1rem;
    }

    .body :global(h2) {
      font-size: 1.5rem;
    }

    .body :global(h3) {
      font-size: 1.2rem;
    }

    .body :global(ul),
    .body :global(ol) {
      font-family: var(--serif);
      font-size: 1.1rem;
      line-height: 1.6;
      margin: 0 0 1.5rem;
      padding-left: 1.5rem;
    }

    .body :global(li) {
      margin-bottom: 0.5rem;
    }

    .body :global(code) {
      font-family: var(--mono);
      font-size: 0.9em;
      background: var(--paper-dim);
      padding: 0.1em 0.3em;
      border-radius: 2px;
    }

    .body :global(pre) {
      background: var(--ink);
      color: var(--paper);
      padding: 1.25rem;
      overflow-x: auto;
      font-size: 0.9rem;
      margin: 1.5rem 0;
      border-radius: 2px;
    }

    .body :global(strong) {
      font-weight: 600;
    }

    .body :global(blockquote) {
      border-left: 3px solid var(--accent);
      padding-left: 1.25rem;
      margin: 1.5rem 0;
      font-style: italic;
      color: var(--muted);
    }

    .sources,
    .concepts {
      margin-top: 3rem;
      padding: 1.5rem;
      background: var(--paper-dim);
      border-left: 3px solid var(--accent);
    }

    .sources h3,
    .concepts h3 {
      font-family: var(--sans);
      font-size: 0.78rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0 0 0.75rem;
      font-weight: 500;
    }

    .sources ul,
    .concepts ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .sources li,
    .concepts li {
      font-family: var(--mono);
      font-size: 0.85rem;
      display: flex;
      gap: 0.75rem;
    }

    .source-type {
      color: var(--muted);
      min-width: 70px;
    }

    .section-nav {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--rule);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .section-nav a {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      text-decoration: none;
      padding: 1rem;
      background: var(--paper-dim);
      transition: background 150ms;
    }

    .section-nav a:hover {
      background: #fff;
    }

    .nav-next {
      text-align: right;
      grid-column: 2;
    }

    .nav-prev {
      grid-column: 1;
    }

    .section-nav .label {
      font-family: var(--sans);
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .section-nav .title {
      font-family: var(--serif);
      font-size: 1.05rem;
    }

    @media (max-width: 640px) {
      .section {
        padding: 1rem 1.5rem 4rem;
      }

      .pull-quote {
        padding: 0 1rem;
      }

      .section-nav {
        grid-template-columns: 1fr;
      }

      .nav-next,
      .nav-prev {
        grid-column: 1;
        text-align: left;
      }
    }
  </style>
</BaseLayout>
