---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Concepts · The Focus.AI Magazines">
  <section class="placeholder">
    <h1>Concepts</h1>
    <p>A cross-cutting glossary linking the vocabulary across all issues. Forthcoming.</p>
  </section>

  <style>
    .placeholder {
      max-width: 720px;
      margin: 0 auto;
      padding: 5rem 3rem;
    }

    h1 {
      font-family: var(--serif);
      font-weight: 300;
      font-size: 3rem;
      margin: 0 0 1rem;
    }

    p {
      font-family: var(--serif);
      font-size: 1.2rem;
      color: var(--muted);
      line-height: 1.5;
    }
  </style>
</BaseLayout>
