---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Concepts · THEFOCUS.AI Magazines">
  <section class="stub">
    <div class="stub-inner">
      <div class="stub-header">
        <span class="uppercase-label stub-eyebrow">
          <span class="spot-number">§</span>&nbsp;Appendix
        </span>
      </div>
      <h1 class="stub-title">Concepts</h1>
      <p class="stub-lede">
        A cross-cutting glossary linking the vocabulary across all issues.
        When you read about <em>instruction budget</em> in STATE, it links
        here; from here it links back to every section that discusses it.
      </p>
      <div class="stub-status mono">
        <span class="spot-number">STATUS:</span> FORTHCOMING
      </div>
    </div>
  </section>

  <style>
    .stub {
      padding: 5rem 2rem;
    }

    .stub-inner {
      max-width: 760px;
      margin: 0 auto;
      background: var(--paper);
      border: 1px solid var(--void);
      padding: 3rem;
      box-shadow: 12px 12px 0 0 rgba(26, 26, 26, 0.1);
    }

    .stub-header {
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--void);
      margin-bottom: 2rem;
    }

    .stub-eyebrow {
      color: var(--alert-red);
    }

    .stub-title {
      font-family: var(--sans);
      font-weight: 900;
      font-size: clamp(2.5rem, 5vw, 4rem);
      line-height: 0.95;
      letter-spacing: -0.03em;
      margin: 0 0 1.5rem;
    }

    .stub-lede {
      font-size: 1.15rem;
      line-height: 1.55;
      color: var(--void);
      margin: 0 0 2rem;
      max-width: 600px;
    }

    .stub-lede em {
      font-style: italic;
      color: var(--rand-blue);
    }

    .stub-status {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: rgba(26, 26, 26, 0.6);
      padding-top: 1rem;
      border-top: 1px dashed var(--rule-subtle);
    }

    @media (max-width: 640px) {
      .stub {
        padding: 2rem 1rem;
      }

      .stub-inner {
        padding: 1.75rem;
      }
    }
  </style>
</BaseLayout>
