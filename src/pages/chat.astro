---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Chat · THEFOCUS.AI Magazines">
  <section class="stub">
    <div class="stub-inner">
      <div class="stub-header">
        <span class="uppercase-label stub-eyebrow">
          <span class="spot-number">§</span>&nbsp;Interface
        </span>
      </div>
      <h1 class="stub-title">Chat with the corpus</h1>
      <p class="stub-lede">
        A conversational interface over every issue, section, source, and
        concept. The markdown in <code>src/content/</code> is the canonical
        source — an MCP server reads it; the chat surface calls the MCP
        server.
      </p>
      <p class="stub-lede-sub">
        Until the web chat ships, the MCP server can be connected directly
        to a Claude Desktop, Cursor, or Goose client.
      </p>
      <div class="stub-status mono">
        <span class="spot-number">STATUS:</span> FORTHCOMING
      </div>
    </div>
  </section>

  <style>
    .stub {
      padding: 5rem 2rem;
    }

    .stub-inner {
      max-width: 760px;
      margin: 0 auto;
      background: var(--paper);
      border: 1px solid var(--void);
      padding: 3rem;
      box-shadow: 12px 12px 0 0 rgba(26, 26, 26, 0.1);
    }

    .stub-header {
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--void);
      margin-bottom: 2rem;
    }

    .stub-eyebrow {
      color: var(--alert-red);
    }

    .stub-title {
      font-family: var(--sans);
      font-weight: 900;
      font-size: clamp(2.5rem, 5vw, 4rem);
      line-height: 0.95;
      letter-spacing: -0.03em;
      margin: 0 0 1.5rem;
    }

    .stub-lede {
      font-size: 1.15rem;
      line-height: 1.55;
      color: var(--void);
      margin: 0 0 1rem;
      max-width: 600px;
    }

    .stub-lede-sub {
      font-size: 1rem;
      line-height: 1.55;
      color: rgba(26, 26, 26, 0.7);
      margin: 0 0 2rem;
      max-width: 600px;
    }

    code {
      font-family: var(--mono);
      font-size: 0.9em;
      background: var(--surface);
      padding: 0.12em 0.4em;
      border-radius: 2px;
    }

    .stub-status {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: rgba(26, 26, 26, 0.6);
      padding-top: 1rem;
      border-top: 1px dashed var(--rule-subtle);
    }

    @media (max-width: 640px) {
      .stub {
        padding: 2rem 1rem;
      }

      .stub-inner {
        padding: 1.75rem;
      }
    }
  </style>
</BaseLayout>
