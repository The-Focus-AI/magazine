---
// 30-second timed signup modal. Same behavior as
// thefocus.ai/reports/aiecode-2025-11 — dismissal persisted in
// localStorage under `focus_newsletter_dismissed`.
---
<div id="newsletter-popup" class="np-root" hidden>
  <div class="np-backdrop" id="np-backdrop"></div>
  <div class="np-modal-wrap">
    <div class="np-modal" role="dialog" aria-modal="true" aria-labelledby="np-heading">
      <button id="np-close" class="np-close" aria-label="Close">×</button>

      <div class="np-eyebrow">Don't miss out</div>
      <h3 id="np-heading" class="np-heading">Stay ahead of the curve.</h3>
      <p class="np-blurb">
        Field reports from AI engineering — what's shipping, what's
        breaking, what's about to change. One email per issue.
      </p>

      <form
        action="https://buttondown.com/api/emails/embed-subscribe/thefocusai"
        method="post"
        class="np-form"
      >
        <input
          type="email"
          name="email"
          id="np-email"
          required
          placeholder="you@domain.com"
          class="np-input"
        />
        <button type="submit" class="np-button">Subscribe →</button>
      </form>

      <button id="np-dismiss" class="np-dismiss">No thanks, I'll pass</button>
    </div>
  </div>
</div>

<style>
  .np-root {
    position: fixed;
    inset: 0;
    z-index: 100;
  }
  .np-root[hidden] { display: none; }

  .np-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 19, 16, 0.7);
    backdrop-filter: blur(4px);
  }

  .np-modal-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .np-modal {
    position: relative;
    background: var(--paper);
    border: 4px solid var(--void);
    box-shadow: 8px 8px 0 0 var(--void);
    max-width: 460px;
    width: 100%;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
    animation: np-pop 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes np-pop {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .np-close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: 0;
    font-size: 28px;
    line-height: 1;
    color: var(--void);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color 150ms ease;
  }
  .np-close:hover { color: var(--alert-red); }

  .np-eyebrow {
    font-family: var(--mono, 'Courier Prime', monospace);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(26, 26, 26, 0.55);
    margin-bottom: 0.75rem;
  }

  .np-heading {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 900;
    font-size: 1.75rem;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    color: var(--void);
    text-transform: none;
  }

  .np-blurb {
    font-size: 14px;
    line-height: 1.5;
    color: rgba(26, 26, 26, 0.7);
    margin: 0 0 1.5rem;
  }

  .np-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .np-input {
    font-family: inherit;
    font-size: 15px;
    padding: 0.75rem 1rem;
    border: 1px solid var(--void);
    background: #fff;
    border-radius: 0;
    color: var(--void);
  }
  .np-input:focus {
    outline: 2px solid var(--rand-blue, #0055aa);
    outline-offset: 1px;
  }

  .np-button {
    font-family: var(--mono, 'Courier Prime', monospace);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.85rem 1.5rem;
    background: var(--void);
    color: var(--paper);
    border: 1px solid var(--void);
    cursor: pointer;
    transition: background 150ms ease, border-color 150ms ease;
  }
  .np-button:hover {
    background: var(--rand-blue, #0055aa);
    border-color: var(--rand-blue, #0055aa);
  }

  .np-dismiss {
    margin-top: 1rem;
    background: none;
    border: 0;
    font-family: var(--mono, 'Courier Prime', monospace);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: rgba(26, 26, 26, 0.45);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    padding: 0.5rem;
  }
  .np-dismiss:hover { color: var(--void); }

  @media print {
    .np-root { display: none !important; }
  }
</style>

<script is:inline>
  (function () {
    const KEY = 'focus_newsletter_dismissed';
    if (typeof window === 'undefined') return;

    function init() {
      const root = document.getElementById('newsletter-popup');
      const closeBtn = document.getElementById('np-close');
      const dismissBtn = document.getElementById('np-dismiss');
      const backdrop = document.getElementById('np-backdrop');
      if (!root) return;
      if (localStorage.getItem(KEY)) return;

      function show() {
        root.hidden = false;
        document.body.style.overflow = 'hidden';
      }
      function hide(persist) {
        root.hidden = true;
        document.body.style.overflow = '';
        if (persist) {
          try { localStorage.setItem(KEY, 'true'); } catch (_) {}
        }
      }

      const t = setTimeout(show, 30000);

      closeBtn && closeBtn.addEventListener('click', () => hide(true));
      dismissBtn && dismissBtn.addEventListener('click', () => hide(true));
      backdrop && backdrop.addEventListener('click', () => hide(false));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !root.hidden) hide(false);
      });
      window.addEventListener('beforeunload', () => clearTimeout(t));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
